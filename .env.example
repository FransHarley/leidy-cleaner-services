POSTGRES_DB=leidy_cleaner
POSTGRES_USER=leidy
POSTGRES_PASSWORD=leidy_dev_password
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/leidy_cleaner
SPRING_DATASOURCE_USERNAME=leidy
SPRING_DATASOURCE_PASSWORD=leidy_dev_password

ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=change-me-local-webhook-token
ASAAS_DEFAULT_CUSTOMER_ID=
ASAAS_CHECKOUT_BILLING_TYPES=CREDIT_CARD
# Configure the Asaas webhook subscription for payment success events.
# Checkout payments reconcile through payment.checkoutSession on PAYMENT_CONFIRMED/PAYMENT_RECEIVED.
# CHECKOUT_PAID remains supported if Asaas emits it for the configured Checkout flow.
ASAAS_CHECKOUT_SUCCESS_URL=http://localhost:5173/pagamento/sucesso
ASAAS_CHECKOUT_CANCEL_URL=http://localhost:5173/pagamento/cancelado
ASAAS_CHECKOUT_EXPIRED_URL=http://localhost:5173/pagamento/expirado

VITE_API_BASE_URL=http://localhost:8080/api/v1
